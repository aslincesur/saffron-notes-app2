# Kopyala bu dosyayı .env olarak ve API key'ini ekle
# ASLA bu dosyayı git'e commit etme!

# Google Gemini API Key (https://aistudio.google.com/app/apikeys adresinden al)
GEMINI_API_KEY=paste_your_api_key_here

# Optional: Server portu (default 3000)
PORT=3000

# Optional: Node environment
NODE_ENV=development
